PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX ds: <https://data.stratigraphy.org/data/gts>
PREFIX geo: <http://www.opengis.net/ont/geosparql#>
PREFIX gts: <http://resource.geosciml.org/ontology/timescale/gts#>
PREFIX gtsd: <https://data.stratigraphy.org/data/gts/>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX rank: <http://resource.geosciml.org/ontology/timescale/rank/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <https://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX thors: <http://resource.geosciml.org/ontology/timescale/thors#>
PREFIX time: <http://www.w3.org/2006/time#>
PREFIX trs: <http://def.isotc211.org/iso19108/2006/TemporalReferenceSystem#>
PREFIX xkos: <http://rdf-vocabulary.ddialliance.org/xkos#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

<http://resource.geosciml.org/classifier/cgi/geologicage/bp>
    a
        trs:TM_CoordinateSystem ,
        time:TRS ;
    trs:TM_CoordinateSystem.interval
        "31556925.445s" ,
        "365.24219265d" ,
        "a" ;
    trs:TM_CoordinateSystem.origin "1950-01-01T00:00:00"^^xsd:dateTime ;
    dcterms:description """Temporal position expressed numerically scaled in years increasing backwards relative to 1950.

Positions in archeologic and 'recent' geologic time are conventionally denoted in years, measured backwards from the present, which is fixed to 1950 when the precision requires it."""@en ;
    rdfs:seeAlso <https://en.wikipedia.org/wiki/Before_Present> ;
    skos:definition "Temporal position expressed numerically scaled in years increasing backwards relative to 1950"@en ;
.

<http://resource.geosciml.org/classifier/cgi/geologicage/ma>
    a
        trs:TM_CoordinateSystem ,
        time:TRS ;
    trs:TM_CoordinateSystem.interval "Ma"@en ;
    trs:TM_CoordinateSystem.origin "2000-01-01T00:00:00"^^xsd:dateTime ;
    dcterms:description """Temporal position expressed numerically scaled in millions of years increasing backwards from the present.

Positions in geologic time are conventionally denoted in millions of years, measured backwards from the present."""@en ;
    rdfs:seeAlso
        <https://doi.org/10.1351%2FPAC-REC-09-01-22> ,
        <https://en.wikipedia.org/wiki/Year#SI_prefix_multipliers> ;
    skos:definition "Temporal position expressed numerically scaled in millions of years increasing backwards from the present"@en ;
.

ds:
    a schema:Dataset ;
    rdfs:seeAlso "https://stratigraphy.org/chart/"^^xsd:anyURI ;
    skos:changeNote "This dataset is a time relations-only version of the Semantic Web version of the 'Geologic Time Scale' created by Simon Cox & Steve Richard in 2005 and maintained by them until 2020. That was a comprehensive dataset with temporal relations, GSSPs and age times all in the single ontology. This dataset excludes GSSP and Chart display data as they are now held in other ICS datasets" ;
    prov:wasDerivedFrom <http://resource.geosciml.org/vocabulary/timescale/gts2020> ;
    schema:codeRepository <https://github.com/i-c-stratigraphy/supermodel> ;
    schema:contributor
        <https://orcid.org/0000-0001-6041-5302> ,
        <https://orcid.org/0000-0002-3884-3420> ;
    schema:copyrightNotice "© 2026 International Commission on Stratigraphy" ;
    schema:copyrightOwner <https://stratigraphy.org> ;
    schema:created "2026-07-18"^^xsd:date ;
    schema:creator <https://orcid.org/0000-0002-8742-7730> ;
    schema:description "A temporal relations-only version of the Geologic Timescale" ;
    schema:license <http://purl.org/NET/rdflicense/cc-by4.0> ;
    schema:modified "2026-07-18"^^xsd:date ;
    schema:name "Geologic Timescale" ;
.

gtsd:
    a rdf:Bag ;
    skos:member
        gtsd:Boundaries ,
        gtsd:GeochronologicEras ;
.

gtsd:BaseAlbian-location
    geo:asWKT "<http://www.opengis.net/def/crs/EPSG/0/4326> POINT(44.4964 5.3114)"^^geo:wktLiteral ;
.

gtsd:BaseNorthgrippian-location
    geo:asWKT "<http://www.opengis.net/def/crs/EPSG/0/4326> POINT(75.1 42.32)"^^geo:wktLiteral ;
.

gtsd:BaseToarcian-location
    geo:asWKT "<http://www.opengis.net/def/crs/EPSG/0/4326> POINT(39.3708 -9.3853)"^^geo:wktLiteral ;
.

gtsd:Boundary-unspecified
    skos:definition "Boundaries of intervals in the chronostratigraphic chart (unspecified)"@en ;
    skos:topConceptOf <http://resource.geosciml.org/vocabulary/timescale/gts2020> ;
.

gtsd:Stratotype-unspecified
    skos:definition "Stratigraphic points providing stratotypes of boundaries in the chronostratigraphic chart (unspecified)"@en ;
    skos:topConceptOf <http://resource.geosciml.org/vocabulary/timescale/gts2020> ;
.

