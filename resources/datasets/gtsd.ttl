gtsd:BaseCambrianSeries3
    a gts:GeochronologicBoundary ;
    dcterms:isReplacedBy gtsd:BaseMiaolingian ;
.

gtsd:BaseUpperCretaceous
    a gts:GeochronologicBoundary ;
    dcterms:isReplacedBy gtsd:BaseLateCretaceous ;
.

gtsd:BaseUpperDevonian
    a gts:GeochronologicBoundary ;
    dcterms:isReplacedBy gtsd:BaseLateDevonian ;
.

gtsd:BaseUpperJurassic
    a gts:GeochronologicBoundary ;
    dcterms:isReplacedBy gtsd:BaseLateJurassic ;
.

gtsd:BaseUpperMississippian
    a gts:GeochronologicBoundary ;
    dcterms:isReplacedBy gtsd:BaseLateMississippian ;
.

gtsd:BaseUpperOrdovician
