PREFIX : <https://data.stratigraphy.org/def/strat/>
PREFIX geo: <http://www.opengis.net/ont/geosparql#>
PREFIX gts: <http://resource.geosciml.org/ontology/timescale/gts#>
PREFIX gut: <http://resource.geosciml.org/classifier/cgi/geologicunittype/>
PREFIX ont: <https://data.stratigraphy.org/def/strat>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <https://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

:Chronometry
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf :ScienceDomain ;
    schema:description "The scientific study of the measurement of time" ;
    schema:name "Chronometric" ;
.

:Early
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf :RelativeChronometricPosition ;
    schema:description "The oldest element in a set with the same parent element" ;
    schema:name "Early" ;
.

:Eonothem
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf gts:StratigraphicSection ;
    schema:citation "https://stratigraphy.org/guide/chron"^^xsd:anyURI ;
    schema:description """An eonothem is a chronostratigraphic unit greater than an erathem. The geochronologic equivalent is an eon. Three eonothems are generally recognized, from older to younger, the Archean, Proterozoic and Phanerozoic eonothems. The combined first two are usually referred to as the Precambrian.

The eons take the same name as their corresponding eonothems.""" ;
    schema:name "Eonothem" ;
.

:Erathem
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf gts:StratigraphicSection ;
    schema:citation "https://stratigraphy.org/guide/chron"^^xsd:anyURI ;
    schema:description """An erathem is a chronostratigraphic unit greater than a system consisting of several systems.

The geochronologic equivalent of an erathem is an era.

The names of erathems in the Phanerozoic were chosen to reflect major changes of the history of life on Earth: Paleozoic (old life), Mesozoic (intermediate life), and Cenozoic (recent life). Eras carry the same name as their corresponding erathems.""" ;
    schema:name "Erathem" ;
.

:Late
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf :RelativeChronometricPosition ;
    schema:description "The youngest element in a set with the same parent element" ;
    schema:name "Late" ;
.

:Lower
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf :RelativeStratigraphicPosition ;
    schema:description "The bottom-most stratigraphic unit in a set with the same parent unit" ;
    schema:name "Lower" ;
.

:Middle
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf :RelativeStratigraphicPosition ;
    schema:description "The middle stratigraphic unit in a set with the same parent unit" ;
    schema:name "Middle" ;
.

:Series
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf gts:StratigraphicSection ;
    schema:citation "https://stratigraphy.org/guide/chron"^^xsd:anyURI ;
    schema:description """The series is a chronostratigraphic unit ranking above subseries or stages and below a system. A series consists of several consecutive subseries, or (when subseries are not used) of several consecutive stages.

The geochronologic equivalent of a series is an epoch.""" ;
    schema:name "Series" ;
.

:Stage
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf gts:StratigraphicSection ;
    schema:citation "https://stratigraphy.org/guide/chron"^^xsd:anyURI ;
    schema:description """A stage is the lowest ranking unit in the chronostratigraphic hierarchy that can be recognized on a global scale.

A stage includes all rocks deposited between two chronostratigraphic horizons defined by GSSPs.""" ;
    schema:name "Stage" ;
.

:Stratigraphy
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf :ScienceDomain ;
    schema:description "The scientific study of layers (strata) of rock, soil, sediment, or archaeological deposits and their arrangement through time" ;
    schema:name "Stratigraphic" ;
.

:Subseries
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf gts:StratigraphicSection ;
    schema:citation "https://stratigraphy.org/guide/chron"^^xsd:anyURI ;
    schema:description """A subseries is a chronostratigraphic unit ranking immediately above stages and below a series. It consists of one or several consecutive stages.

The geochronologic equivalent of a subseries is a subepoch.""" ;
    schema:name "Subseries" ;
.

:System
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf gts:StratigraphicSection ;
    schema:citation "https://stratigraphy.org/guide/chron"^^xsd:anyURI ;
    schema:description """A system is a unit of major rank in the conventional chronostratigraphic hierarchy, above a series and below an erathem. A system is composed of several consecutive series.

The geochronologic equivalent of a system is a period. As an exception, the rank of subsystem (Mississippian, Pennsylvanian) is used for the Carboniferous System.""" ;
    schema:name "System" ;
.

:Upper
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf :RelativeStratigraphicPosition ;
    schema:description "The highest stratigraphic unit in a set with the same parent unit" ;
    schema:name "Upper" ;
.

gts:StratigraphicPoint
    a owl:Class ;
    geo:sfWithin gts:StratigraphicSection ;
    rdfs:isDefinedBy <http://resource.geosciml.org/ontology/timescale/gts> ;
    schema:description "A specified position within an agreed stratigraphic section, used to calibrate the temporal position (age) of a boundary within the geologic timescale." ;
    schema:name "Stratigraphic Point"@en ;
.

<http://purl.org/NET/rdflicense/cc-by4.0>
    schema:name "Creative Commons - Attribution 4.0 International"@en ;
    schema:url "http://creativecommons.org/licenses/by/4.0/legalcode"^^xsd:anyURI ;
.

gut:chronostratigraphic_unit
    schema:name "Chronostratigraphic Unit" ;
.

gut:geologic_unit
    a owl:Class ;
    rdfs:isDefinedBy <http://resource.geosciml.org/classifierscheme/cgi/2016.01/geologicunittype> ;
    schema:citation "http://resource.geosciml.org/classifierscheme/cgi/2016.01/geologicunittype"^^xsd:anyURI ;
    schema:name "Geologic Unit" ;
    schema:description "This is the root concept for the Geologic Unit Type, type hierarchy." ;
.

:1.0
    schema:name "1.0" ;
.

<https://orcid.org/0000-0002-8742-7730>
    a schema:Person ;
    schema:email "nick@kurrawong.ai"^^xsd:anyURI ;
    schema:name "Nicholas J. Car" ;
.

:RelativeChronometricPosition
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf :RelativePosition ;
    schema:description "A position of a Chronometric element relative to another" ;
    schema:name "Relative Chronometric Position" ;
.

:RelativePosition
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    schema:description "A position of something relative to another" ;
    schema:name "Relative Position" ;
.

:ScienceDomain
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    schema:description "A major area or branch of scientific study" ;
    schema:name "Science Domain" ;
.

<http://resource.geosciml.org/ontology/timescale/gts>
    schema:name "Geologic Timescale model" ;
.

<https://stratigraphy.org>
    a schema:Organization ;
    schema:name "International Commission on Stratigraphy" ;
    schema:url "https://stratigraphy.org"^^xsd:anyURI ;
.

:RelativeStratigraphicPosition
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf :RelativePosition ;
    schema:description "A position of a Stratigraphic Unit relative to another" ;
    schema:name "Relative Stratigraphic Position" ;
.

gts:StratigraphicSection
    a owl:Class ;
    rdfs:isDefinedBy <http://resource.geosciml.org/ontology/timescale/gts> ;
    rdfs:subClassOf gut:geologic_unit ;
    owl:equivalentClass gut:chronostratigraphic_unit ;
    schema:description "An agreed Geologic Unit, which may a stratigraphic point that is used to calibrate the temporal position (age) of a boundary within the geologic timescale." ;
    schema:name "Stratigraphic Section"@en ;
.

:GSSP
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf gts:StratigraphicPoint ;
    schema:alternateName "GSSP" ;
    schema:description "GSSPs are reference points on stratigraphic sections of rock which define the lower boundaries of stages on the International Chronostratigraphic Chart" ;
    schema:name "Global Boundary Stratotype Sections and Point" ;
    schema:citation "Definition from stratigraphy.org" ;
.

ont:
    a owl:Ontology ;
    owl:versionIRI :1.0 ;
    skos:changeNote """2026-06: Added upper classes for scientific domain, relative position

2025-12: Created for the Data Chart and GSSPs DB release, late 2025, mostly from the Stratigraphic Guide at https://stratigraphy.org/guide/chron""" ;
    schema:codeRepository "https://github.com/i-c-stratigraphy/chart"^^xsd:anyURI ;
    schema:copyrightHolder <https://stratigraphy.org> ;
    schema:copyrightNotice "(c) 2025 International Commission on Stratigraphy" ;
    schema:creator <https://orcid.org/0000-0002-8742-7730> ;
    schema:dateCreated "2025-12-01"^^xsd:date ;
    schema:dateIssued "2026-06-28"^^xsd:date ;
    schema:dateModified "2026-06-22"^^xsd:date ;
    schema:description "An ontology for describing stratigraphic objects" ;
    schema:license <http://purl.org/NET/rdflicense/cc-by4.0> ;
    schema:name "Stratigraphy Model" ;
    schema:publisher <https://stratigraphy.org> ;
    schema:version "1.0" ;
.
